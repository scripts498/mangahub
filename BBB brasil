-- ==================== ANIMAÇÃO E INICIALIZAÇÃO ====================

task.spawn(function()
    -- Animação simples de progresso
    for i = 1, 100 do
        task.wait(0.08)
        TweenService:Create(ProgressBar, TweenInfo.new(0.1), {
            Size = UDim2.fromOffset((i / 100) * 480, 12)
        }):Play()
        
        if i == 30 then StatusText.Text = "Conectando ao jogo..." end
        if i == 60 then StatusText.Text = "Carregando módulos..." end
        if i == 85 then StatusText.Text = "Quase pronto..." end
    end
    
    StatusText.Text = "Pronto!"
    task.wait(0.5)
    
    -- Fade out e destruição COMPLETA
    TweenService:Create(GlassContainer, TweenInfo.new(0.5), {Size = UDim2.fromOffset(0, 0)}):Play()
    TweenService:Create(LoadingFrame, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
    
    task.wait(0.6)
    LoadingGui:Destroy()
    
    -- ESPERA ADICIONAL para garantir que o CoreGui esteja limpo
    task.wait(0.5)
    
    -- ==================== INICIALIZAR FLUENT ====================
    
    local success, Fluent = pcall(function()
        return loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
    end)
    
    if not success or not Fluent then
        warn("Erro ao carregar Fluent:", tostring(Fluent))
        return
    end
    
    local successSave, SaveManager = pcall(function()
        return loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/SaveManager.lua"))()
    end)
    
    local successInterface, InterfaceManager = pcall(function()
        return loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/InterfaceManager.lua"))()
    end)
    
    local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
    local windowSize = isMobile and UDim2.fromOffset(400, 300) or UDim2.fromOffset(580, 460)
    local tabWidth = isMobile and 120 or 160
    
    local Window = Fluent:CreateWindow({
        Title = "manga hub/V4.8/Brasil",
        SubTitle = "BBB Brasil",
        TabWidth = tabWidth,
        Size = windowSize,
        Acrylic = true,
        Theme = "Dark",
        MinimizeKey = Enum.KeyCode.LeftControl
    })
    
    getgenv().MangaHubWindow = Window
    
    local Tabs = {
        Main = Window:AddTab({ Title = "Votação", Icon = "check-square" }),
        Player = Window:AddTab({ Title = "Player", Icon = "user" }),
        Teleport = Window:AddTab({ Title = "Teleport", Icon = "map-pin" }),
        Evento = Window:AddTab({ Title = "Evento", Icon = "star" })
    }
    
    local Options = Fluent.Options
    
    -- ==================== SISTEMA DE VOTAÇÃO ====================
    
    local NetFolder = ReplicatedStorage:WaitForChild("Packages", 10):WaitForChild("Net", 10)
    local VoteRemote = NetFolder:WaitForChild("GetOption", 10)
    
local selectedPlayer = nil
local votingEnabled = false

-- mapa pra não dar confusão entre DisplayName duplicado
local playerMap = {}

local function getPlayerList()
    local list = {}

    playerMap = {}

    for _, p in ipairs(Players:GetPlayers()) do
        local label = p.DisplayName .. " (@" .. p.Name .. ")"
        
        table.insert(list, label)
        playerMap[label] = p
    end

    return list
end

local function votePlayer(playerObj)
    if not playerObj or not VoteRemote then return end

    pcall(function()
        VoteRemote:FireServer({ playerObj.Name })
    end)
end

-- MAIN TAB
local Dropdown = Tabs.Main:AddDropdown("PlayerDropdown", {
    Title = "Selecionar Jogador",
    Values = getPlayerList(),
    Multi = false,
    Default = 1
})

Dropdown:OnChanged(function(value)
    selectedPlayer = playerMap[value]
end)

Tabs.Main:AddButton({
    Title = "Votar no Jogador",
    Callback = function()
        if selectedPlayer then
            votePlayer(selectedPlayer)

            Fluent:Notify({
                Title = "Voto enviado",
                Content = "Você votou em " .. selectedPlayer.DisplayName,
                Duration = 3
            })
        else
            Fluent:Notify({
                Title = "Erro",
                Content = "Nenhum jogador selecionado",
                Duration = 3
            })
        end
    end
})

Tabs.Main:AddButton({
    Title = "Atualizar Lista",
    Callback = function()
        Dropdown:SetValues(getPlayerList())

        Fluent:Notify({
            Title = "Lista Atualizada",
            Content = "Jogadores recarregados com sucesso!",
            Duration = 3
        })
    end
})
    
    local Toggle = Tabs.Main:AddToggle("VoteToggle", {
        Title = "Votar nesta pessoa ( melhorado )",
        Default = false
    })
    
    Toggle:OnChanged(function()
        votingEnabled = Options.VoteToggle.Value
        
        if votingEnabled then
            if not selectedPlayer or selectedPlayer == "" then
                Fluent:Notify({ Title = "Erro", Content = "Selecione um jogador primeiro!", Duration = 4 })
                Options.VoteToggle:SetValue(false)
                return
            end
            
            Fluent:Notify({ Title = "Votação Iniciada", Content = "Votando RÁPIDO em: " .. selectedPlayer.DisplayName, Duration = 3 })
        else
            Fluent:Notify({ Title = "Votação Parada", Content = "A votação foi interrompida!", Duration = 3 })
        end
    end)
    
    -- Spam loop separado
    task.spawn(function()
        while true do
            task.wait()
            if votingEnabled and selectedPlayer then
                for i = 1, 10 do
                    votePlayer(selectedPlayer)
                end
            end
        end
    end)
    
    Tabs.Main:AddParagraph({
        Title = "Informações",
        Content = "Use apenas em pessoas no paredão.\n\nQuando ativado:\n• 95% de chance da pessoa sair\n• 5% de chance de não sair"
    })
    
    -- PLAYER TAB
    local velocidadeValue = 16
    local speedEnabled = false
    
    Tabs.Player:AddInput("Velocidade", {
        Title = "Velocidade",
        Default = "16",
        Numeric = true,
        Callback = function(Value)
            velocidadeValue = tonumber(Value) or 16
        end
    })
    
    Tabs.Player:AddToggle("PegarVelocidade", {
        Title = "Pegar Velocidade",
        Default = false,
        Callback = function(Value)
            speedEnabled = Value
            if speedEnabled then
                Fluent:Notify({ Title = "Velocidade Ativada", Content = "Velocidade: " .. velocidadeValue, Duration = 3 })
            else
                local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                if hum then hum.WalkSpeed = 16 end
                Fluent:Notify({ Title = "Velocidade Desativada", Content = "Velocidade normal restaurada", Duration = 3 })
            end
        end
    })
    
    task.spawn(function()
        while true do
            task.wait()
            if speedEnabled then
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChild("Humanoid")
                if hum then hum.WalkSpeed = velocidadeValue end
            end
        end
    end)
    
    -- TELEPORT TAB
    local selectedTpPlayer = nil
    
    local TpDropdown = Tabs.Teleport:AddDropdown("TpPlayerDropdown", {
        Title = "Players",
        Values = getPlayerList(),
        Multi = false,
        Default = 1
    })
    
    TpDropdown:OnChanged(function(Value)
        selectedTpPlayer = Value
    end)
    
    Tabs.Teleport:AddButton({
        Title = "Atualizar Lista",
        Callback = function()
            TpDropdown:SetValues(getPlayerList())
            Fluent:Notify({ Title = "Lista Atualizada", Content = "Lista atualizada com sucesso", Duration = 3 })
        end
    })
    
    Tabs.Teleport:AddButton({
        Title = "TP para esse player",
        Callback = function()
            if not selectedTpPlayer or selectedTpPlayer == "" then
                Fluent:Notify({ Title = "Erro", Content = "Selecione um jogador primeiro!", Duration = 4 })
                return
            end
            
            local target = Players:FindFirstChild(selectedTpPlayer)
            local myChar = LocalPlayer.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") and myRoot then
                myRoot.CFrame = target.Character.HumanoidRootPart.CFrame
                Fluent:Notify({ Title = "Teleportado", Content = "Você foi até " .. selectedTpPlayer, Duration = 3 })
            else
                Fluent:Notify({ Title = "Erro", Content = "Jogador inválido ou sem personagem", Duration = 4 })
            end
        end
    })
    
    -- EVENTO TAB
    local autoJogoEnabled = false
    
    local function baterNaFruta()
        pcall(function()
            local minigame = Workspace:FindFirstChild("MinigameCrazykitchen")
            if not minigame then return end
            local remote = minigame:FindFirstChild("🍎2")
            if remote and remote:IsA("RemoteEvent") then
                remote:FireServer()
            end
        end)
    end
    
    Tabs.Evento:AddToggle("AutoJogoToggle", {
        Title = "Auto Jogo da cozinha",
        Default = false,
        Callback = function(Value)
            autoJogoEnabled = Value
            if autoJogoEnabled then
                Fluent:Notify({ Title = "Auto Jogo Ativado", Content = "Fire automático ativado!", Duration = 3 })
            else
                Fluent:Notify({ Title = "Auto Jogo Desativado", Content = "Auto jogo desligado.", Duration = 3 })
            end
        end
    })
    
    task.spawn(function()
        while true do
            task.wait(0.06)
            if autoJogoEnabled then
                baterNaFruta()
            end
        end
    end)
    
    local autoLavaEnabled = false
    local bodyPosition = nil
    local frozenPosition = nil
    
    local function congelarPlayer()
        pcall(function()
            if not LocalPlayer.Character then return end
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            
            frozenPosition = hrp.CFrame.Position
            if not bodyPosition then
                bodyPosition = Instance.new("BodyPosition")
                bodyPosition.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                bodyPosition.D = 1000
                bodyPosition.P = 10000
                bodyPosition.Parent = hrp
            end
            bodyPosition.Position = frozenPosition
        end)
    end
    
    local function descongelarPlayer()
        pcall(function()
            if bodyPosition then
                bodyPosition:Destroy()
                bodyPosition = nil
            end
            frozenPosition = nil
        end)
    end
    
    local function verificarEDestruirBolaDeFogo()
        pcall(function()
            local lavaModel = Workspace:FindFirstChild("Lava")
            if not lavaModel then return end
            for _, obj in pairs(lavaModel:GetDescendants()) do
                if obj:IsA("BasePart") and obj.Name == "BolaDeFogo" then
                    obj:Destroy()
                end
            end
        end)
    end
    
    Tabs.Evento:AddToggle("AutoLavaToggle", {
        Title = "Auto Jogo de Lava",
        Default = false,
        Callback = function(Value)
            autoLavaEnabled = Value
            if autoLavaEnabled then
                Fluent:Notify({ Title = "Auto Lava Ativado", Content = "Você está protegido!", Duration = 3 })
                congelarPlayer()
            else
                autoLavaEnabled = false
                descongelarPlayer()
                Fluent:Notify({ Title = "Auto Lava Desativado", Content = "Você pode se mover novamente!", Duration = 3 })
            end
        end
    })
    
    task.spawn(function()
        while true do
            task.wait(0)
            if autoLavaEnabled then
                verificarEDestruirBolaDeFogo()
                if frozenPosition and LocalPlayer.Character then
                    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if hrp and bodyPosition then
                        bodyPosition.Position = frozenPosition
                    end
                end
            end
        end
    end)
    
    Tabs.Evento:AddParagraph({
        Title = "Informações Auto Lava",
        Content = "Esta função:\n- Te congela no lugar\n- Deleta automaticamente BolaDeFogo\n- Você fica flutuando se o chão sumir"
    })
    
    -- BOTÃO MINIMIZAR
