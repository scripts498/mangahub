local function randomName()
    local str = ""
    for i = 1, 12 do
        local rnd = math.random(1, 3)
        if rnd == 1 then
            str = str .. string.char(math.random(65, 90))
        elseif rnd == 2 then
            str = str .. string.char(math.random(97, 122))
        else
            str = str .. math.random(0, 9)
        end
    end
    return str
end

