local connections = {}
local function safeDisconnect(name)
    if connections[name] then
        pcall(function() connections[name]:Disconnect() end)
        connections[name] = nil
    end
end
local function safeConnect(name, func)
    safeDisconnect(name)
    connections[name] = RunService.Heartbeat:Connect(func)
end

