local function getOrCreateEsp(plr)
    if espDrawings[plr] then return espDrawings[plr] end

    local d = {}

    d.box = Drawing.new("Square")
    d.box.Visible = false
    d.box.Thickness = 1.2
    d.box.Filled = false
    d.box.Color = Color3.fromRGB(255, 50, 50)
    d.box.Transparency = 0.8
    table.insert(drawings, d.box)

    d.boxFill = Drawing.new("Square")
    d.boxFill.Visible = false
    d.boxFill.Thickness = 0
    d.boxFill.Filled = true
    d.boxFill.Color = Color3.fromRGB(255, 50, 50)
    d.boxFill.Transparency = 0.15
    table.insert(drawings, d.boxFill)

    d.line = Drawing.new("Line")
    d.line.Visible = false
    d.line.Thickness = 1.5
    d.line.Color = Color3.fromRGB(0, 255, 200)
    d.line.Transparency = 0.7
    table.insert(drawings, d.line)

    d.name = Drawing.new("Text")
    d.name.Visible = false
    d.name.Size = 13
    d.name.Center = true
    d.name.Outline = true
    d.name.OutlineColor = Color3.fromRGB(0, 0, 0)
    d.name.Color = Color3.fromRGB(255, 255, 255)
    d.name.Font = 2
    table.insert(drawings, d.name)

    d.healthBar = Drawing.new("Line")
    d.healthBar.Visible = false
    d.healthBar.Thickness = 2
    d.healthBar.Color = Color3.fromRGB(0, 255, 100)
    d.healthBar.Transparency = 0.9
    table.insert(drawings, d.healthBar)

    espDrawings[plr] = d
    return d
end

local function removeEsp(plr)
    local d = espDrawings[plr]
    if d then
        for _, obj in pairs(d) do
            if obj and obj.Remove then
                pcall(function() obj:Remove() end)
            end
        end
        espDrawings[plr] = nil
    end
end



local function startAnticheatLoop(char)
    if not char then return end
    task.spawn(function()
        while char and char.Parent do
            local folder = char:FindFirstChild("FJsMovementAnticheat")
            if folder then
                for _, child in pairs(folder:GetChildren()) do
                    if child:IsA("NumberValue") then
                        child.Value = 0
                    end
                end
                local punish = folder:FindFirstChild("OnPunishment")
                if punish and punish:IsA("RemoteEvent") then
                    punish:Destroy()
                end
            end
            task.wait(0.05)
        end
    end)
end

