local function isVisible(target)
    if not states.wallCheck or states.locked then return true end
    if not target or not target:FindFirstChild("Head") then return false end

    local origin = camera.CFrame.Position
    local targetPos = target.Head.Position
    local direction = (targetPos - origin).Unit * (targetPos - origin).Magnitude

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.FilterDescendantsInstances = {player.Character}
    rayParams.IgnoreWater = true

    local result = Workspace:Raycast(origin, direction, rayParams)
    if not result then return true end

    return result.Instance and result.Instance:IsDescendantOf(target)
end

local function getClosestPlayer()
    if states.locked then return nil end
    local closest, closestDist = nil, math.huge
    local mousePos = UserInputService:GetMouseLocation()
    local camPos = camera.CFrame.Position

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and not isWhitelisted(plr) and plr.Character then
            local char = plr.Character
            local head = char:FindFirstChild("Head")
            local humanoid = char:FindFirstChild("Humanoid")

            if head and humanoid and humanoid.Health > 0 then
                local dist = (head.Position - camPos).Magnitude
                if dist <= settings.maxDistance and dist > 5 then
                    local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                        if screenDist <= settings.fovRadius and screenDist < closestDist then
                            if isVisible(char) then
                                closestDist = screenDist
                                closest = {character = char, head = head, screenPos = screenPos}
                            end
                        end
                    end
                end
            end
        end
    end
    return closest
end


-- Problema: "0.5m abaixo de mim" sai da tela quando olha pra cima
-- Solução: Linha vai do CENTRO DA TELA (crosshair) até o torso do alvo

local function updateDrawingEsp()
    if states.locked and not isAdmin then
        for _, d in pairs(espDrawings) do
            d.box.Visible = false
            d.boxFill.Visible = false
            d.line.Visible = false
            d.name.Visible = false
            d.healthBar.Visible = false
        end
        return
    end

    local viewport = camera.ViewportSize
    local screenCenter = Vector2.new(viewport.X / 2, viewport.Y / 2)

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and not isWhitelisted(plr) and plr.Character then
            local char = plr.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            local humanoid = char:FindFirstChild("Humanoid")
            local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")

            if hrp and head and humanoid and humanoid.Health > 0 then
                local d = getOrCreateEsp(plr)

                -- Box ESP
                if states.espBox then
                    local headPos, headOnScreen = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                    local footPos, footOnScreen = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

                    if headOnScreen and footOnScreen and headPos.Z > 0 and footPos.Z > 0 then
                        local boxHeight = math.abs(headPos.Y - footPos.Y)
                        local boxWidth = boxHeight * 0.55
                        local boxPos = Vector2.new(
                            math.floor(headPos.X - boxWidth / 2),
                            math.floor(headPos.Y)
                        )

                        d.box.Size = Vector2.new(math.floor(boxWidth), math.floor(boxHeight))
                        d.box.Position = boxPos
                        d.box.Visible = true

                        d.boxFill.Size = d.box.Size
                        d.boxFill.Position = d.box.Position
                        d.boxFill.Visible = true

                        local healthPercent = humanoid.Health / humanoid.MaxHealth
                        local barHeight = boxHeight * healthPercent
                        local barPos = Vector2.new(boxPos.X - 6, boxPos.Y + (boxHeight - barHeight))

                        d.healthBar.From = Vector2.new(barPos.X, boxPos.Y + boxHeight)
                        d.healthBar.To = Vector2.new(barPos.X, boxPos.Y)
                        d.healthBar.Color = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
                        d.healthBar.Visible = true
                    else
                        d.box.Visible = false
                        d.boxFill.Visible = false
                        d.healthBar.Visible = false
                    end
                else
                    d.box.Visible = false
                    d.boxFill.Visible = false
                    d.healthBar.Visible = false
                end

               
                
                if states.espLine and torso then
                    local targetPos, targetOnScreen = camera:WorldToViewportPoint(torso.Position)

                    -- Só desenha se o alvo está visível na tela
                    if targetOnScreen and targetPos.Z > 0 then
                        d.line.From = screenCenter
                        d.line.To = Vector2.new(targetPos.X, targetPos.Y)
                        d.line.Visible = true
                    else
                        d.line.Visible = false
                    end
                else
                    d.line.Visible = false
                end

                -- Name + Distance
                if states.espBox or states.espLine then
                    local namePos, nameOnScreen = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1.2, 0))
                    if nameOnScreen and namePos.Z > 0 then
                        d.name.Position = Vector2.new(namePos.X, namePos.Y)
                        d.name.Text = plr.Name .. " [" .. math.floor((hrp.Position - camera.CFrame.Position).Magnitude) .. "m]"
                        d.name.Visible = true
                    else
                        d.name.Visible = false
                    end
                else
                    d.name.Visible = false
                end
            else
                removeEsp(plr)
            end
        else
            removeEsp(plr)
        end
    end
end

local currentTarget = nil

local function aimAssist()
    if not states.aimAssist or (states.locked and not isAdmin) then return end

    local target = getClosestPlayer()
    if target then
        currentTarget = target
        local headPos = target.head.Position + Vector3.new(0, 0.15, 0)
        local targetCF = CFrame.lookAt(camera.CFrame.Position, headPos)
        camera.CFrame = camera.CFrame:Lerp(targetCF, settings.aimAssistSmoothness)
    else
        currentTarget = nil
    end
end

local function aimbot()
    if not states.aimbot or (states.locked and not isAdmin) then return end

    local target = getClosestPlayer()
    if target then
        currentTarget = target
        local headPos = target.head.Position + Vector3.new(0, 0.1, 0)
        camera.CFrame = CFrame.lookAt(camera.CFrame.Position, headPos)
    else
        currentTarget = nil
    end
end


