local espObjects = {}
local function clearESP()
    for _, obj in pairs(espObjects) do
        if obj then pcall(function() obj:Remove() end) end
    end
    espObjects = {}
end

local function createESPBox(target)
    if not target or not target:FindFirstChild("HumanoidRootPart") then return end
    
    local box = Drawing.new("Square")
    box.Thickness = 1.5
    box.Color = Color3.fromRGB(255, 50, 50)
    box.Transparency = 0.8
    box.Filled = false
    box.Visible = true
    
    local nameTag = Drawing.new("Text")
    nameTag.Size = 13
    nameTag.Color = Color3.new(1, 1, 1)
    nameTag.Center = true
    nameTag.Outline = true
    nameTag.Visible = true
    
    table.insert(espObjects, box)
    table.insert(espObjects, nameTag)
    
    return box, nameTag
end

local function updateESP()
    if states.locked and not isAdmin then return end
    clearESP()
    
    if not (states.espBox or states.espHighlight) then return end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and not isWhitelisted(plr) and plr.Character then
            local char = plr.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            local humanoid = char:FindFirstChild("Humanoid")
            
            if hrp and head and humanoid and humanoid.Health > 0 then
                if states.espHighlight then
                    if not char:FindFirstChild("ESPHighlight") then
                        local highlight = Instance.new("Highlight")
                        highlight.Name = "ESPHighlight"
                        highlight.Adornee = char
                        highlight.FillColor = Color3.fromRGB(255, 0, 0)
                        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                        highlight.FillTransparency = 0.6
                        highlight.OutlineTransparency = 0
                        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        highlight.Parent = char
                    end
                else
                    local hl = char:FindFirstChild("ESPHighlight")
                    if hl then hl:Destroy() end
                end
                
                if states.espBox then
                    local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                    if onScreen then
                        local size = 1000 / pos.Z
                        local box, nameTag = createESPBox(char)
                        
                        box.Size = Vector2.new(size * 0.6, size * 1.2)
                        box.Position = Vector2.new(pos.X - box.Size.X/2, pos.Y - box.Size.Y/2)
                        
                        nameTag.Text = plr.Name .. " [" .. math.floor((hrp.Position - camera.CFrame.Position).Magnitude) .. "m]"
                        nameTag.Position = Vector2.new(pos.X, pos.Y - size * 0.7)
                    end
                end
            end
        end
    end
end

local currentTarget = nil

local function aimAssist()
    if not states.aimAssist or (states.locked and not isAdmin) then return end
    
    local target = getClosestPlayer()
    if target then
        currentTarget = target
        local headPos = target.head.Position + Vector3.new(0, 0.15, 0)
        
        local targetCF = CFrame.lookAt(camera.CFrame.Position, headPos)
        camera.CFrame = camera.CFrame:Lerp(targetCF, settings.aimAssistSmoothness)
    else
        currentTarget = nil
    end
end

local function aimbot()
    if not states.aimbot or (states.locked and not isAdmin) then return end
    
    local target = getClosestPlayer()
    if target then
        currentTarget = target
        local headPos = target.head.Position + Vector3.new(0, 0.1, 0)
        camera.CFrame = CFrame.lookAt(camera.CFrame.Position, headPos)
    else
        currentTarget = nil
    end
end

local function setupCharacter()
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            if (states.speed and not (states.locked and not isAdmin)) or states.adminFPS then
                humanoid.WalkSpeed = settings.speedValue
            else
                humanoid.WalkSpeed = 16
            end
        end
        
        if (states.noclip and not (states.locked and not isAdmin)) or states.adminFPS then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end
end

