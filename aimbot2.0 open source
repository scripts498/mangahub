local function updateSlider(input)
    local pos = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
    local value = math.floor(settings.minFov + (pos * (settings.maxFov - settings.minFov)))

    settings.fovRadius = value
    fovLabel.Text = "FOV: " .. value

    sliderFill.Size = UDim2.new(pos, 0, 1, 0)
    sliderKnob.Position = UDim2.new(pos, -8 * guiScale, 0.5, -8 * guiScale)
end

local draggingSlider = false
local draggingPanel = false
local dragStart = nil
local startPos = nil

sliderKnob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingSlider = true
    end
end)

sliderBg.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingSlider = true
        updateSlider(input)
    end
end)

dragHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not panel.Visible then return end
        draggingPanel = true
        dragStart = input.Position
        startPos = panel.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateSlider(input)
    elseif draggingPanel and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        panel.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingSlider = false
        draggingPanel = false
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    local key = input.KeyCode
    if key == Enum.KeyCode.Insert then
        toggleButton.MouseButton1Click:Fire()
    elseif key == Enum.KeyCode.Q then
        aimAssistBtn.MouseButton1Click:Fire()
    elseif key == Enum.KeyCode.E then
        aimbotBtn.MouseButton1Click:Fire()
    elseif key == Enum.KeyCode.F then
        espBoxBtn.MouseButton1Click:Fire()
    elseif key == Enum.KeyCode.G then
        espLineBtn.MouseButton1Click:Fire()
    elseif key == Enum.KeyCode.T then
        fovBtn.MouseButton1Click:Fire()
    elseif key == Enum.KeyCode.Z then
        speedBtn.MouseButton1Click:Fire()
    elseif key == Enum.KeyCode.X then
        noclipBtn.MouseButton1Click:Fire()
    elseif isAdmin and key == Enum.KeyCode.C then
        if disableUsersBtn then disableUsersBtn.MouseButton1Click:Fire() end
    elseif isAdmin and key == Enum.KeyCode.V then
        if fpsKillerBtn then fpsKillerBtn.MouseButton1Click:Fire() end
    end
end)


